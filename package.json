{
  "name": "celestia",
  "version": "1.0.0",
  "description": "二次元游戏启动台",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc",
    "build:renderer": "webpack",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "package": "npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.celestia.app",
    "productName": "Celestia",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "zip"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "css-loader": "^7.1.2",
    "electron": "^41.5.0",
    "electron-builder": "^26.0.12",
    "html-webpack-plugin": "^5.6.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}